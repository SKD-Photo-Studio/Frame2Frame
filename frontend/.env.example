# -----------------------------------------------------------------------------
# 🔑 SUPABASE CONFIGURATION
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key
NEXT_PRIVATE_SUPABASE_SECRET_KEY=your-service-role-key

# -----------------------------------------------------------------------------
# 🌐 APP CONFIGURATION
# -----------------------------------------------------------------------------
# Local: http://localhost:3000/api | Production: Set in Cloudflare Pages dashboard
NEXT_PUBLIC_APP_URL=http://localhost:3000/api
NEXT_PUBLIC_DEV_BYPASS_AUTH=false
NEXT_PUBLIC_MAINTENANCE_MODE=false
NEXT_PUBLIC_LOCAL_MAINTENANCE_MODE=false

# -----------------------------------------------------------------------------
# 📊 ANALYTICS (PostHog)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_POSTHOG_KEY=your_posthog_project_api_key
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# -----------------------------------------------------------------------------
# 🤖 AI CONFIGURATION
# -----------------------------------------------------------------------------
GOOGLE_AI_API_KEY=your_google_ai_studio_api_key

# -----------------------------------------------------------------------------
# ☁️ CLOUDFLARE CONFIGURATION
# -----------------------------------------------------------------------------
CLOUDFLARE_ACCOUNT_ID=your_account_id
CLOUDFLARE_API_TOKEN=your_api_token
